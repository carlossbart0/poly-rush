# Port Rust del bot Python — solo necesitamos lo minimo para DRY_RUN bilateral.
RUST_LOG=info,bot_polymarket_rust=debug

# Polymarket WS endpoint (no auth para market channel).
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Gamma discovery endpoint.
GAMMA_URL=https://gamma-api.polymarket.com

# Parametros de arbitraje bilateral.
ARB_MIN_EDGE_PER_UNIT=0.002
ARB_MAX_SIZE_USDC=20
ARB_FEE_RATE_BPS=180
ARB_SLIPPAGE_BUFFER_BPS=20
ARB_MARKETS_REFRESH_SECONDS=120
ARB_HORIZON_SECONDS=7200
ARB_GAMMA_LIMIT=500

DB_PATH=state/rust_bot.jsonl
STOP_FILE_PATH=state/STOP

# === Credenciales de live trading (NO commitear el .env real) ===
# PRIVATE_KEY=0x... (64 hex chars, sin commitear)
# SIGNATURE_TYPE=0 (EOA) | 1 (Proxy) | 2 (GnosisSafe)
# FUNDER_ADDRESS=0x... (requerido si SIGNATURE_TYPE != 0)

# === Safety limits configurables (SafetyLimits::from_env_or_default) ===
# Defaults si no se setean: 30 / 3 / 12.
# SAFETY_MAX_TOTAL_USDC: capital total acumulado del run.
# SAFETY_MAX_PER_TRADE_USDC: monto maximo por trade individual.
# SAFETY_MAX_TRADES_PER_HOUR: rate limit por hora (sliding window).
SAFETY_MAX_TOTAL_USDC=30
SAFETY_MAX_PER_TRADE_USDC=3
SAFETY_MAX_TRADES_PER_HOUR=12

# === TP-on-place automatico ===
# Default si no set: 15. Cada entry exitoso postea limit SELL GTC al
# entry_price * (1 + LAGARB_TP_PCT/100), capped 0.99.
# Setear "off" o "0" para desactivar el TP automatico.
LAGARB_TP_PCT=15

# === Momentum threshold para Strategy A en basis points ===
# Default si no set: 3. Razonable: 1-20.
# 1 bps = ruido browniano, 3-5 bps = signal real, 10+ bps = muy selectivo.
# Ver RESEARCH.md para analisis detallado.
LAGARB_MOMENTUM_BPS=3
